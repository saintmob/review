rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isValidPlanId(planId) {
      return planId is string && planId.size() <= 128 && planId.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /showPlans/{planId} {
      allow read: if isValidPlanId(planId);
      allow write: if false;
    }

    match /global/state {
      // Legacy particle-system state is no longer used by the plan editor.
      allow read: if true;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
